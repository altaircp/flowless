---
import PublicLayout from '../../layouts/PublicLayout.astro';
import JoinQueueForm from '../../components/queue/JoinQueueForm.tsx';
import { dataStore } from '../../data/store';

const branches = dataStore.branches.filter((b) => b.isActive).map((b) => ({
  id: b.id,
  name: b.name,
  address: b.address,
  city: b.city,
  isActive: b.isActive,
}));

const services = dataStore.services.filter((s) => s.isActive).map((s) => ({
  id: s.id,
  name: s.name,
  description: s.description,
  icon: s.icon,
  estimatedDurationMinutes: s.estimatedDurationMinutes,
  isActive: s.isActive,
  branchIds: s.branchIds,
}));

const queues = dataStore.queues.map((q) => ({
  id: q.id,
  branchId: q.branchId,
  serviceId: q.serviceId,
  state: q.state,
  prefix: q.prefix,
  currentNumber: q.currentNumber,
  activeTicketIds: q.activeTicketIds,
  averageWaitMinutes: q.averageWaitMinutes,
  averageServiceMinutes: q.averageServiceMinutes,
}));
---

<PublicLayout title="Join Queue">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-2">Join the Queue</h1>
      <p class="text-gray-500 text-base sm:text-lg">Select your branch and service to get started</p>
    </div>
    <JoinQueueForm
      client:load
      branches={branches}
      services={services}
      queues={queues}
    />
  </div>
</PublicLayout>
