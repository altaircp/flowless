---
import PublicLayout from '../../layouts/PublicLayout.astro';
import FeedbackForm from '../../components/feedback/FeedbackForm';
import { dataStore } from '../../data/store';
import { TicketStatus } from '../../data/enums';

export const prerender = false;

const { ticketId } = Astro.params;

const ticket = ticketId ? dataStore.getTicket(ticketId) : undefined;

let serviceName = '';
let branchName = '';
let staffName = '';
let isValidTicket = false;

if (ticket && ticket.status === TicketStatus.Completed) {
  isValidTicket = true;
  const service = dataStore.getService(ticket.serviceId);
  const branch = dataStore.getBranch(ticket.branchId);
  const staffMember = ticket.staffId ? dataStore.getStaffMember(ticket.staffId) : undefined;

  serviceName = service?.name ?? 'Service';
  branchName = branch?.name ?? 'Branch';
  staffName = staffMember?.name ?? '';
}
---

<PublicLayout title="Feedback">
  <section class="py-10 px-4 sm:px-6">
    <div class="max-w-lg mx-auto">
      {isValidTicket && ticketId ? (
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 sm:p-8">
          <FeedbackForm
            client:load
            ticketId={ticketId}
            serviceName={serviceName}
            branchName={branchName}
            staffName={staffName}
          />
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 2a10 10 0 100 20 10 10 0 000-20z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-slate-800 mb-2">
            {ticket ? 'Feedback Not Available' : 'Ticket Not Found'}
          </h2>
          <p class="text-slate-500 mb-6">
            {ticket
              ? 'Feedback can only be submitted for completed visits.'
              : 'We could not find a ticket with this ID. Please check the link and try again.'}
          </p>
          <a
            href="/"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 text-white text-sm font-medium rounded-lg hover:bg-brand-700 transition-colors"
          >
            Back to Home
          </a>
        </div>
      )}
    </div>
  </section>
</PublicLayout>
