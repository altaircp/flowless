---
export const prerender = false;
import PublicLayout from '../../layouts/PublicLayout.astro';
import TicketCard from '../../components/queue/TicketCard.tsx';
import { dataStore } from '../../data/store';

const { id } = Astro.params;

const ticket = id ? dataStore.getTicket(id) : undefined;

let ticketJson = '';
let notificationsJson = '[]';

if (ticket) {
  const branch = dataStore.getBranch(ticket.branchId);
  const service = dataStore.getService(ticket.serviceId);
  const counter = ticket.counterId ? dataStore.getCounter(ticket.counterId) : undefined;

  ticketJson = JSON.stringify({
    id: ticket.id,
    ticketNumber: ticket.ticketNumber,
    status: ticket.status,
    position: ticket.position,
    estimatedWaitMinutes: ticket.estimatedWaitMinutes,
    createdAt: ticket.createdAt,
    calledAt: ticket.calledAt,
    servingStartedAt: ticket.servingStartedAt,
    completedAt: ticket.completedAt,
    branchName: branch?.name ?? 'Unknown Branch',
    serviceName: service?.name ?? 'Unknown Service',
    serviceIcon: service?.icon ?? '',
    counterName: counter?.displayName,
  });

  const notifications = dataStore.notifications
    .filter((n) => n.ticketId === ticket.id)
    .sort((a, b) => b.createdAt.localeCompare(a.createdAt))
    .map((n) => ({
      id: n.id,
      type: n.type,
      title: n.title,
      message: n.message,
      createdAt: n.createdAt,
      isRead: n.isRead,
    }));

  notificationsJson = JSON.stringify(notifications);
}
---

<PublicLayout title="Ticket Status">
  <div class="max-w-lg mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    {ticket ? (
      <div>
        <div class="text-center mb-6">
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1">Ticket Status</h1>
          <p class="text-gray-500 text-sm">Track your queue position in real-time</p>
        </div>
        <TicketCard
          client:load
          ticket={ticketJson}
          notifications={notificationsJson}
        />
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={1.5}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Ticket Not Found</h2>
        <p class="text-gray-500 mb-6">The ticket you're looking for doesn't exist or has expired.</p>
        <a href="/join" class="inline-block py-3 px-6 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition-colors">
          Join a Queue
        </a>
      </div>
    )}
  </div>
</PublicLayout>
