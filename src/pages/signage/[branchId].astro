---
export const prerender = false;
import SignageLayout from '../../layouts/SignageLayout.astro';
import NowServing from '../../components/signage/NowServing';
import QueueList from '../../components/signage/QueueList';
import AnnouncementBar from '../../components/signage/AnnouncementBar';
import SignageClock from '../../components/signage/SignageClock';
import { dataStore } from '../../data/store';

const { branchId } = Astro.params;

const branch = dataStore.getBranch(branchId!);
if (!branch) {
  return Astro.redirect('/');
}

const counters = dataStore.getCountersByBranch(branchId!);
const tickets = dataStore.getActiveTicketsByBranch(branchId!);
const services = dataStore.getServicesByBranch(branchId!);
const stats = dataStore.getBranchStats(branchId!);
---

<SignageLayout title={`${branch.name} - Digital Signage`}>
  <div class="flex flex-col h-full w-full">
    {/* Top bar: branch name + clock */}
    <div class="flex items-center justify-between px-8 py-4">
      <div class="flex items-center gap-4">
        <svg class="w-10 h-10 text-emerald-400" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="currentColor" />
          <path d="M8 12h16M8 16h12M8 20h8" stroke="white" stroke-width="2" stroke-linecap="round" />
        </svg>
        <div>
          <h1 class="text-2xl font-bold text-white">{branch.name}</h1>
          <p class="text-sm text-slate-400">FlowLess Queue Management</p>
        </div>
      </div>
      <SignageClock client:load />
    </div>

    {/* Main content */}
    <div class="flex-1 flex gap-6 px-8 py-2 min-h-0">
      {/* Left: Now Serving (60%) */}
      <div class="w-[60%] flex flex-col min-h-0">
        <NowServing
          client:load
          counters={JSON.stringify(counters)}
          tickets={JSON.stringify(tickets)}
        />
      </div>

      {/* Right: Queue List (40%) */}
      <div class="w-[40%] flex flex-col min-h-0">
        <QueueList
          client:load
          tickets={JSON.stringify(tickets)}
          services={JSON.stringify(services)}
        />
      </div>
    </div>

    {/* Bottom: Announcement bar */}
    <AnnouncementBar
      client:load
      branchName={branch.name}
      avgWait={stats.averageWait}
    />
  </div>
</SignageLayout>
