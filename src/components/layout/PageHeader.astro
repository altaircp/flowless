---
interface Breadcrumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: Breadcrumb[];
}

const { title, subtitle, breadcrumbs } = Astro.props;
---

<div class="mb-8">
  {breadcrumbs && breadcrumbs.length > 0 && (
    <nav class="flex items-center gap-1.5 text-sm text-slate-500 mb-3" aria-label="Breadcrumb">
      {breadcrumbs.map((crumb, i) => (
        <>
          {i > 0 && (
            <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          )}
          {crumb.href ? (
            <a href={crumb.href} class="hover:text-slate-700 transition-colors">{crumb.label}</a>
          ) : (
            <span class="text-slate-800 font-medium">{crumb.label}</span>
          )}
        </>
      ))}
    </nav>
  )}

  <h1 class="text-2xl font-bold text-slate-900">{title}</h1>

  {subtitle && (
    <p class="mt-1 text-sm text-slate-500">{subtitle}</p>
  )}
</div>
