---
interface Props {
  padding?: 'sm' | 'md' | 'lg';
  hover?: boolean;
  class?: string;
}

const {
  padding = 'md',
  hover = false,
  class: className = '',
} = Astro.props;

const paddingClasses: Record<string, string> = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const classes = [
  'bg-white rounded-xl shadow-sm border border-slate-200',
  paddingClasses[padding],
  hover ? 'hover:shadow-md transition-shadow' : '',
  className,
].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
