---
interface Props {
  value: number;
  variant?: 'brand' | 'success' | 'warning' | 'danger';
  size?: 'sm' | 'md';
  class?: string;
}

const {
  value,
  variant = 'brand',
  size = 'md',
  class: className = '',
} = Astro.props;

const clampedValue = Math.max(0, Math.min(100, value));

const variantClasses: Record<string, string> = {
  brand: 'bg-brand-600',
  success: 'bg-green-500',
  warning: 'bg-amber-500',
  danger: 'bg-red-500',
};

const sizeClasses: Record<string, string> = {
  sm: 'h-1.5',
  md: 'h-2.5',
};
---

<div class:list={['w-full bg-slate-200 rounded-full overflow-hidden', sizeClasses[size], className]} role="progressbar" aria-valuenow={clampedValue} aria-valuemin={0} aria-valuemax={100}>
  <div
    class:list={['h-full rounded-full transition-all duration-300', variantClasses[variant]]}
    style={`width: ${clampedValue}%`}
  ></div>
</div>
