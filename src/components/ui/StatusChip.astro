---
interface Props {
  status: 'on_time' | 'delayed' | 'critical' | 'completed' | 'idle';
  class?: string;
}

const { status, class: className = '' } = Astro.props;

const config: Record<string, { label: string; dotColor: string; textColor: string; bgColor: string }> = {
  on_time: {
    label: 'On Time',
    dotColor: 'bg-queue-ontime',
    textColor: 'text-green-700',
    bgColor: 'bg-green-50',
  },
  delayed: {
    label: 'Delayed',
    dotColor: 'bg-queue-delayed',
    textColor: 'text-amber-700',
    bgColor: 'bg-amber-50',
  },
  critical: {
    label: 'Critical',
    dotColor: 'bg-queue-critical',
    textColor: 'text-red-700',
    bgColor: 'bg-red-50',
  },
  completed: {
    label: 'Completed',
    dotColor: 'bg-status-completed',
    textColor: 'text-indigo-700',
    bgColor: 'bg-indigo-50',
  },
  idle: {
    label: 'Idle',
    dotColor: 'bg-status-idle',
    textColor: 'text-slate-600',
    bgColor: 'bg-slate-50',
  },
};

const { label, dotColor, textColor, bgColor } = config[status];
---

<span class:list={['inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium', bgColor, textColor, className]}>
  <span class:list={['w-1.5 h-1.5 rounded-full', dotColor]}></span>
  {label}
</span>
