---
import Button from '../ui/Button.astro';
---

<section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-blue-50/50 to-indigo-50/60">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(99,102,241,0.06),transparent_50%),radial-gradient(circle_at_80%_80%,rgba(37,99,235,0.06),transparent_50%)]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="max-w-xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-100/80 text-brand-700 text-sm font-medium mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
          Now in public beta
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 leading-[1.1]">
          Eliminate Wait Time
          <span class="text-brand-600"> Frustration</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-slate-600 leading-relaxed">
          Reduce perceived wait times by up to 40%, improve customer satisfaction scores, and give your team the tools to deliver effortless service. FlowLess is the modern queue management platform built for high-traffic service environments.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <Button variant="primary" size="lg" href="/join">
            Start Free Trial
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </Button>
          <Button variant="secondary" size="lg" href="#how-it-works">
            <svg class="w-4 h-4 mr-2 text-brand-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
            </svg>
            Watch Demo
          </Button>
        </div>

        <div class="mt-8 flex items-center gap-6 text-sm text-slate-500">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            14-day free trial
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            No credit card
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            Cancel anytime
          </span>
        </div>
      </div>

      <!-- Right: Dashboard mockup -->
      <div class="relative lg:ml-8">
        <div class="relative rounded-2xl border border-slate-200/80 bg-white shadow-2xl shadow-slate-200/50 overflow-hidden">
          <!-- Mockup toolbar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-slate-50 border-b border-slate-200/80">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-amber-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="flex-1 mx-4">
              <div class="h-6 bg-slate-200/60 rounded-md max-w-[200px] mx-auto flex items-center justify-center text-xs text-slate-400 font-mono">app.flowless.io</div>
            </div>
          </div>

          <!-- Mockup content -->
          <div class="p-5 space-y-4">
            <!-- Stats row -->
            <div class="grid grid-cols-3 gap-3">
              <div class="rounded-lg bg-brand-50 border border-brand-100 p-3">
                <div class="text-xs text-brand-600 font-medium">In Queue</div>
                <div class="text-2xl font-bold text-brand-700 mt-0.5">24</div>
              </div>
              <div class="rounded-lg bg-green-50 border border-green-100 p-3">
                <div class="text-xs text-green-600 font-medium">Serving</div>
                <div class="text-2xl font-bold text-green-700 mt-0.5">8</div>
              </div>
              <div class="rounded-lg bg-amber-50 border border-amber-100 p-3">
                <div class="text-xs text-amber-600 font-medium">Avg Wait</div>
                <div class="text-2xl font-bold text-amber-700 mt-0.5">4m</div>
              </div>
            </div>

            <!-- Queue list -->
            <div class="space-y-2">
              <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Live Queue</div>
              <div class="flex items-center justify-between rounded-lg bg-green-50/60 border border-green-100/60 p-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-bold">A</div>
                  <div>
                    <div class="text-sm font-semibold text-slate-800">Ticket #A-017</div>
                    <div class="text-xs text-slate-500">Counter 3 &middot; Serving now</div>
                  </div>
                </div>
                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 text-green-700">Serving</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-slate-50 border border-slate-100 p-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-brand-500 text-white flex items-center justify-center text-sm font-bold">B</div>
                  <div>
                    <div class="text-sm font-semibold text-slate-800">Ticket #B-042</div>
                    <div class="text-xs text-slate-500">Est. wait: 3 min</div>
                  </div>
                </div>
                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-700">Waiting</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-slate-50 border border-slate-100 p-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-indigo-500 text-white flex items-center justify-center text-sm font-bold">C</div>
                  <div>
                    <div class="text-sm font-semibold text-slate-800">Ticket #C-108</div>
                    <div class="text-xs text-slate-500">Est. wait: 7 min</div>
                  </div>
                </div>
                <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-700">Waiting</span>
              </div>
            </div>

            <!-- Progress bar -->
            <div>
              <div class="flex items-center justify-between text-xs mb-1.5">
                <span class="text-slate-600 font-medium">Queue throughput</span>
                <span class="text-brand-600 font-semibold">87%</span>
              </div>
              <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-brand-500 to-brand-600 rounded-full" style="width: 87%"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative elements -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-brand-200/30 rounded-full blur-2xl"></div>
        <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-indigo-200/30 rounded-full blur-2xl"></div>
      </div>
    </div>
  </div>
</section>
