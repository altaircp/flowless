---
import StarRating from '../ui/StarRating.astro';

const testimonials = [
  {
    quote: 'FlowLess cut our average wait time from 22 minutes to under 8. Customer complaints about queues dropped by 70%. The virtual queueing feature alone was worth the switch.',
    name: 'Sarah Chen',
    role: 'Branch Operations Manager',
    company: 'Pacific National Bank',
    category: 'Banking',
    rating: 5,
  },
  {
    quote: 'Our patients used to dread the waiting room. Now they check in from the parking lot and get a text when it is their turn. Satisfaction scores went from 3.2 to 4.7 in three months.',
    name: 'Dr. Marcus Rivera',
    role: 'Clinic Administrator',
    company: 'Greenfield Health Partners',
    category: 'Healthcare',
    rating: 5,
  },
  {
    quote: 'We serve 400+ citizens daily across 12 counters. FlowLess smart routing alone saved us two full-time positions worth of wasted time. The analytics are a game changer for planning.',
    name: 'Janet Okonkwo',
    role: 'Director of Public Services',
    company: 'Metro County Government',
    category: 'Government',
    rating: 5,
  },
];

const categoryIcons: Record<string, string> = {
  Banking: 'bank',
  Healthcare: 'health',
  Government: 'government',
};
---

<section class="py-20 sm:py-28 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <span class="text-sm font-semibold text-brand-600 tracking-wide uppercase">Testimonials</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">
        Trusted by service leaders
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        See how organizations across industries use FlowLess to deliver better experiences.
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <div class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 shadow-sm flex flex-col">
          <!-- Category badge -->
          <div class="flex items-center gap-2 mb-5">
            <div class="w-8 h-8 rounded-lg bg-brand-50 text-brand-600 flex items-center justify-center">
              {categoryIcons[t.category] === 'bank' && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
                </svg>
              )}
              {categoryIcons[t.category] === 'health' && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                </svg>
              )}
              {categoryIcons[t.category] === 'government' && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                </svg>
              )}
            </div>
            <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">{t.category}</span>
          </div>

          <!-- Stars -->
          <StarRating rating={t.rating} size="sm" class="mb-4" />

          <!-- Quote -->
          <blockquote class="text-slate-700 leading-relaxed flex-1 mb-6">
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-5 border-t border-slate-100">
            <div class="w-10 h-10 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center font-semibold text-sm">
              {t.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="text-sm font-semibold text-slate-900">{t.name}</div>
              <div class="text-xs text-slate-500">{t.role}, {t.company}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
