---
const steps = [
  {
    number: '1',
    title: 'Customers join the queue',
    description: 'Via smartphone, kiosk, or walk-in. They pick a service, get a ticket, and receive an estimated wait time instantly.',
    icon: 'join',
  },
  {
    number: '2',
    title: 'Smart routing assigns them',
    description: 'Our algorithm matches customers to the best available counter based on service type, agent skills, and real-time load.',
    icon: 'route',
  },
  {
    number: '3',
    title: 'Real-time updates keep them informed',
    description: 'Customers track their position live via SMS, app, or digital signage. No more "am I next?" anxiety.',
    icon: 'notify',
  },
];
---

<section id="how-it-works" class="py-20 sm:py-28 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <span class="text-sm font-semibold text-brand-600 tracking-wide uppercase">How it works</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">
        How FlowLess works
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Three simple steps to transform your customer experience.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Connecting line (desktop) -->
      <div class="hidden lg:block absolute top-16 left-[calc(16.67%+24px)] right-[calc(16.67%+24px)] h-0.5 bg-gradient-to-r from-brand-200 via-brand-300 to-brand-200"></div>

      <div class="grid lg:grid-cols-3 gap-12 lg:gap-8">
        {steps.map((step, index) => (
          <div class="relative text-center">
            <!-- Step number circle -->
            <div class="relative z-10 mx-auto w-14 h-14 rounded-full bg-brand-600 text-white flex items-center justify-center text-xl font-bold shadow-lg shadow-brand-200 mb-6">
              {step.number}
            </div>

            <!-- Icon -->
            <div class="mx-auto w-12 h-12 rounded-xl bg-white border border-slate-200 shadow-sm flex items-center justify-center text-brand-600 mb-5">
              {step.icon === 'join' && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
                </svg>
              )}
              {step.icon === 'route' && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
              )}
              {step.icon === 'notify' && (
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                </svg>
              )}
            </div>

            <h3 class="text-xl font-semibold text-slate-900 mb-3">{step.title}</h3>
            <p class="text-slate-600 leading-relaxed max-w-xs mx-auto">{step.description}</p>

            {/* Mobile connecting arrow */}
            {index < steps.length - 1 && (
              <div class="lg:hidden flex justify-center mt-8">
                <svg class="w-6 h-6 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
